# Backend service
APP_NAME=Moonshill
PORT=8080
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/moonshill
JWT_SECRET=replace-with-a-long-random-secret
SESSION_SECRET=replace-with-a-long-random-secret

# Frontend + CORS
CLIENT_ORIGIN=http://localhost:3000
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Email OTP auth
RESEND_API_KEY=
EMAIL_FROM=Moonshill <auth@yourdomain.com>

# BNB Chain / app config
CHAIN_ID=56
BNB_RPC_URL=https://bsc-dataseed.binance.org/
ADMIN_WALLET=
SEED_DEMO_DATA=false

# X OAuth
X_CLIENT_ID=
X_CLIENT_SECRET=
X_CALLBACK_URL=http://localhost:8080/api/auth/x/callback
X_HANDLE=moonshillfun
